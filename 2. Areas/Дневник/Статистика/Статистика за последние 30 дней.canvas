{
	"nodes":[
		{"id":"ff8367e38aee40da","type":"text","text":"# График настроения\n```dataviewjs\nconst daysAgo = 30;\nconst endDate = new Date();\nconst startDate = new Date();\nstartDate.setDate(endDate.getDate() - daysAgo);\n\nfunction toDate(v) {\n    if (!v) return null;\n    if (v instanceof Date && !isNaN(v.getTime())) return v;\n    try { if (v.toJSDate) { const d = v.toJSDate(); if (!isNaN(d)) return d; } } catch {}\n    try { if (v.toDate)   { const d = v.toDate();   if (!isNaN(d)) return d; } } catch {}\n    const parsed = new Date(String(v));\n    return isNaN(parsed.getTime()) ? null : parsed;\n}\nfunction toNumber(v) {\n    if (v === null || v === undefined) return null;\n    if (typeof v === \"number\") return v;\n    const n = Number(String(v).replace(\",\", \".\"));\n    return isNaN(n) ? null : n;\n}\n\nconst rawPages = dv.pages('\"2. Areas/Дневник/Ежедневник и задачи\"');\nconst items = [];\n\nfor (const p of rawPages) {\n    let noteDate = toDate(p.date) || toDate(p.file?.day) || toDate(p.file?.ctime) || toDate(p.file?.cday);\n    if (!noteDate && p.file?.name) {\n        noteDate = toDate(p.file.name.split('.')[0]);\n    }\n    if (!noteDate || noteDate < startDate || noteDate > endDate) continue;\n\n    const mood = toNumber(p[\"Настроение\"] ?? p[\"самоощущение\"] ?? p[\"настроение\"]);\n    if (mood === null) continue;\n\n    items.push({ date: noteDate, mood: Math.max(1, Math.min(100, Math.round(mood))) });\n}\n\nitems.sort((a, b) => a.date - b.date);\n\nif (items.length === 0) {\n    dv.paragraph(\"📉 Нет данных по «Настроение» за последние 30 дней.\");\n} else {\n    const dates = items.map(i => `${String(i.date.getDate()).padStart(2,'0')}.${String(i.date.getMonth()+1).padStart(2,'0')}`);\n    const feelings = items.map(i => i.mood);\n    const avgMood = Math.round(feelings.reduce((a,b)=>a+b,0)/feelings.length);\n\n    // контейнер: пустой второй аргумент чтобы Dataview не вставлял лишний текст\n    const chartContainer = dv.el(\"div\", \"\");\n    // жёстко нейтрализуем возможные отступы темы/Dataview\n    chartContainer.style.width = \"100%\";\n    chartContainer.style.height = \"500px\";\n    chartContainer.style.margin = \"0\";\n    chartContainer.style.marginTop = \"0\";\n    chartContainer.style.marginBottom = \"0\";\n    chartContainer.style.padding = \"0\";\n    chartContainer.style.paddingTop = \"0\";\n    chartContainer.style.paddingBottom = \"0\";\n    chartContainer.style.display = \"block\";\n    chartContainer.style.lineHeight = \"0\";\n    chartContainer.style.fontSize = \"0\";\n    chartContainer.style.position = \"relative\";\n\n    // Подготовка конфигурации графика\n    const chartConfig = {\n        type: 'line',\n        data: {\n            labels: dates,\n            datasets: [{\n                label: `Настроение (среднее: ${avgMood})`,\n                data: feelings,\n                borderColor: 'rgba(75,192,192,1)',\n                backgroundColor: 'rgba(75,192,192,0.1)',\n                borderWidth: 2,\n                pointRadius: 4,\n                pointHoverRadius: 6,\n                fill: true,\n                tension: 0.3\n            }]\n        },\n        options: {\n            animation: false,\n            responsive: true,\n            maintainAspectRatio: false,\n            plugins: {\n                legend: { position: 'top', labels: { font: { size: 12 } } },\n                tooltip: { enabled: true, mode: 'index', intersect: false, callbacks: { label: ctx => `Настроение: ${ctx.parsed?.y ?? ctx.raw ?? ''}` } }\n            },\n            scales: {\n                x: { grid: { display: false } },\n                y: { min: 1, max: 100, ticks: { stepSize: 10, font: { size: 11 } }, grid: { color: 'rgba(200,200,200,0.2)' } }\n            },\n            interaction: { mode: 'nearest', axis: 'x', intersect: false }\n        }\n    };\n\n    try {\n        // Если renderChart существует — НЕ создаём canvas сами, передаём пустой контейнер\n        if (typeof window.renderChart === \"function\") {\n            window.renderChart(chartConfig, chartContainer);\n        } else if (typeof window.Chart === \"function\") {\n            // Если Chart глобально — создаём canvas и рендерим его\n            const canvas = document.createElement(\"canvas\");\n            canvas.style.display = \"block\";\n            canvas.style.width = \"100%\";\n            canvas.style.height = \"100%\";\n            canvas.style.margin = \"0\";\n            canvas.style.padding = \"0\";\n            chartContainer.appendChild(canvas);\n            new Chart(canvas.getContext('2d'), chartConfig);\n        } else {\n            dv.paragraph(\"❌ Chart.js / renderChart недоступны в этом окружении.\");\n        }\n    } catch (e) {\n        console.error(\"Ошибка при рендере графика:\", e);\n        dv.paragraph(\"Ошибка при отрисовке графика — глянь консоль разработчика.\");\n    }\n}\n```","x":-760,"y":-400,"width":1060,"height":640,"color":"5"},
		{"id":"c0213d0257a02f3c","type":"text","text":"# Завершено и отменено задач\n```dataviewjs\nconst now = window.moment();\nconst thirtyDaysAgo = now.clone().subtract(30, 'days');\n\nlet completed = 0;\nlet cancelled = 0;\n\nfor (const page of dv.pages('\"2. Areas/Дневник/Ежедневник и задачи\"')) {\n    const mDate = window.moment(page.file.day);\n    if (!mDate.isValid() || mDate.isBefore(thirtyDaysAgo) || mDate.isAfter(now)) continue;\n    if (!page.file.tasks) continue;\n\n    for (const t of page.file.tasks) {\n        if (t.status === 'x') completed++;\n        else if (t.status === '-') cancelled++;\n    }\n}\n\ndv.table([\"✅ Завершено\", \"❌ Отменено\"], [[completed.toString(), cancelled.toString()]]);\n```\n","x":694,"y":-440,"width":934,"height":200,"color":"3"},
		{"id":"73ec8e743db72208","type":"text","text":"# Теги выполненных задач\n```dataviewjs\nconst daysAgo = 30;\nconst endDate = new Date();\nconst startDate = new Date();\nstartDate.setDate(endDate.getDate() - daysAgo);\n\nconst tasks = dv.pages('\"2. Areas/Дневник/Ежедневник и задачи\"')\n    .where(p => p.file.tasks && p.file.tasks.length > 0);\n\nif (!tasks || tasks.length === 0) {\n    dv.paragraph(\"❌ Нет задач.\");\n} else {\n    const filteredTasks = [];\n\n    for (const page of tasks) {\n        for (const task of page.file.tasks) {\n            if (task.completed) {\n                const taskDate = new Date(task.completion);\n                if (!isNaN(taskDate.getTime()) && taskDate >= startDate && taskDate <= endDate) {\n                    if (task.tags && task.tags.length > 0) {\n                        filteredTasks.push(...task.tags);\n                    }\n                }\n            }\n        }\n    }\n\n    if (filteredTasks.length === 0) {\n        dv.paragraph(\"❌ Нет выполненных задач с тегами за последние 30 дней.\");\n    } else {\n        const tagCounts = {};\n        for (const tag of filteredTasks) {\n            tagCounts[tag] = (tagCounts[tag] || 0) + 1;\n        }\n\n        const sortedEntries = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);\n        const labels = sortedEntries.map(entry => entry[0]);\n        const data = sortedEntries.map(entry => entry[1]);\n        const totalValue = data.reduce((a, b) => a + b, 0);\n\n        function generateColor(index, total, opacity = 1) {\n            const hue = (index * 360 / Math.max(1, total)) % 360;\n            return `hsla(${hue}, 70%, 60%, ${opacity})`;\n        }\n\n        const backgroundColors = labels.map((_, i) => generateColor(i, labels.length, 0.75));\n        const borderColors = labels.map((_, i) => generateColor(i, labels.length, 1));\n\n        const chartData = {\n            type: 'pie',\n            data: {  // ← Вот здесь было пропущено \"data:\"\n                labels: labels,\n                datasets: [{\n                    label: 'Частота тегов',\n                    data: data,\n                    backgroundColor: backgroundColors,\n                    borderColor: borderColors,\n                    borderWidth: 2\n                }]\n            },\n            options: {\n                responsive: true,\n                animation: false,\n                plugins: {\n                    legend: {\n                        position: 'top',\n                        labels: {\n                            boxWidth: 28,\n                            padding: 10,\n                            font: { size: 28 },\n                            generateLabels: function(chart) {\n                                const dataset = chart.data.datasets[0];\n                                return chart.data.labels.map((label, i) => {\n                                    const percentage = totalValue ? ((dataset.data[i] / totalValue) * 100).toFixed(1) : 0;\n                                    return {\n                                        text: `${label} ${percentage}%`,\n                                        fillStyle: dataset.backgroundColor[i],\n                                        strokeStyle: dataset.borderColor[i],\n                                        lineWidth: 2,\n                                        hidden: false,\n                                        index: i\n                                    };\n                                });\n                            }\n                        }\n                    },\n                    tooltip: {\n                        callbacks: {\n                            label: function(context) {\n                                const label = context.label || '';\n                                const value = context.raw || 0;\n                                const percentage = totalValue ? ((value / totalValue) * 100).toFixed(1) : 0;\n                                return `${label}: ${value} (${percentage}%)`;\n                            }\n                        },\n                        bodyFont: {\n                            size: 20\n                        },\n                        titleFont: {\n                            size: 22\n                        },\n                        padding: 12,\n                        displayColors: false\n                    },\n                    datalabels: {\n                        formatter: (value, ctx) => {\n                            const percentage = totalValue ? ((value / totalValue) * 100).toFixed(1) : 0;\n                            return `${percentage}%`;\n                        },\n                        color: '#fff',\n                        font: {\n                            weight: 'bold',\n                            size: 12\n                        },\n                        anchor: 'center',\n                        align: 'center'\n                    }\n                }\n            }\n        };\n\n        if (window.Chart && window.ChartDataLabels && !window.Chart.plugins.getAll().some(p => p.id === 'datalabels')) {\n            window.Chart.register(window.ChartDataLabels);\n        } else if (!window.ChartDataLabels) {\n            delete chartData.options.plugins.datalabels;\n        }\n\n        window.renderChart(chartData, this.container);\n    }\n}\n```\n","x":-760,"y":280,"width":1060,"height":1240,"color":"1"},
		{"id":"6dfacaaa8b49dc71","type":"text","text":"Статистика собирается только из папки `Дневник/Ежедневник и задачи` **(включая все подпапки)**, остальные папки хранилища игнорируются, дабы не тормозило. Если хотите добавить папку для сканирования, отредактируйте код при помощи ИИ.","x":160,"y":1560,"width":811,"height":280},
		{"id":"2ebf8d03cf95f9d8","type":"text","text":"``` dataviewjs\n// --- начало: настройки и хелперы\nconst daysAgo = 30;\nconst endDate = new Date();\nconst startDate = new Date();\nstartDate.setDate(endDate.getDate() - daysAgo);\n\nfunction toDate(v) {\n    if (!v) return null;\n    if (v instanceof Date && !isNaN(v.getTime())) return v;\n    try {\n        if (typeof v.toJSDate === \"function\") {\n            const d = v.toJSDate();\n            if (d instanceof Date && !isNaN(d.getTime())) return d;\n        }\n        if (typeof v.toDate === \"function\") {\n            const d = v.toDate();\n            if (d instanceof Date && !isNaN(d.getTime())) return d;\n        }\n    } catch (e) {}\n    const parsed = new Date(String(v));\n    return isNaN(parsed.getTime()) ? null : parsed;\n}\n\nfunction toNumber(v) {\n    if (v === null || v === undefined) return null;\n    if (typeof v === \"number\" && isFinite(v)) return v;\n    if (typeof v === \"string\") {\n        const n = Number(v.trim().replace(',', '.'));\n        return isFinite(n) ? n : null;\n    }\n    try {\n        const n = Number(v.valueOf ? v.valueOf() : v);\n        return isFinite(n) ? n : null;\n    } catch (e) { return null; }\n}\n\nfunction toBool(v) {\n    if (v === true || v === false) return v;\n    if (v === null || v === undefined) return false;\n    const s = String(v).trim().toLowerCase();\n    return ['true','yes','y','1','✔','✓','on'].includes(s);\n}\n\n// --- получаем страницы\nconst pagesIterator = dv.pages('\"2. Areas/Дневник/Ежедневник и задачи\"');\nlet validPages = [];\n\nfor (const p of pagesIterator) {\n    if (!p.file || !p.file.path) continue;\n\n    // определяем дату заметки\n    let pageDate = null;\n    if (p.date) pageDate = toDate(p.date);\n    if (!pageDate && p.file && p.file.name) {\n        const nameWithoutExt = p.file.name.includes('.') ? p.file.name.split('.')[0] : p.file.name;\n        const byName = toDate(nameWithoutExt);\n        if (byName) pageDate = byName;\n    }\n    if (!pageDate && p.file && (p.file.cday || p.file.ctime || p.file.day)) {\n        pageDate = toDate(p.file.cday || p.file.ctime || p.file.day);\n    }\n\n    if (pageDate && pageDate >= startDate && pageDate <= endDate) {\n        validPages.push({ page: p, _displayDate: pageDate });\n    }\n}\n\n// --- Дедупликация: ключируем по дате YYYY-MM-DD и выбираем \"лучшую\" заметку на дату\nconst byDateMap = new Map();\n\nfunction dateKey(d) {\n    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;\n}\n\nfor (const entry of validPages) {\n    const key = dateKey(entry._displayDate);\n    const candidate = entry.page;\n\n    // считаем \"баллы\" — количество заполненных релевантных полей\n    let score = 0;\n    if (toNumber(candidate[\"Настроение\"] ?? candidate[\"самоощущение\"] ?? candidate[\"настроение\"]) !== null) score++;\n    if (toBool(candidate[\"Желание действовать\"] ?? candidate[\"желание действовать\"])) score++;\n    if (toBool(candidate[\"Сон до 23:00\"] ?? candidate[\"Сон до 23\"] ?? candidate[\"сон до 23:00\"])) score++;\n    if (toBool(candidate[\"Доволен ли продуктивностью\"] ?? candidate[\"доволен ли продуктивностью\"] ?? candidate[\"доволен продуктивностью\"])) score++;\n    if (toNumber(candidate[\"Unity, часы\"] ?? candidate[\"Unity часы\"] ?? candidate[\"Unity\"] ?? candidate[\"unity\"]) !== null) score++;\n\n    const existing = byDateMap.get(key);\n    if (!existing) {\n        byDateMap.set(key, { entry, score });\n    } else {\n        if (score > existing.score) {\n            byDateMap.set(key, { entry, score });\n        }\n    }\n}\n\n// финальный массив уникальных по дате записей\nconst finalPages = Array.from(byDateMap.values()).map(x => x.entry);\n\nif (finalPages.length === 0) {\n    dv.paragraph(`❌ Нет данных за последние ${daysAgo} дней.`);\n} else {\n    const days = finalPages.length;\n\n    let countЖелание = 0;\n    let countСонДо23 = 0;\n    let countДоволенПродукт = 0;\n    let totalMood = 0;\n    let moodCount = 0;\n    let totalUnityHours = 0;\n    let unityCount = 0;\n\n    for (const entry of finalPages) {\n        const p = entry.page;\n        const moodRaw = p[\"Настроение\"] ?? p[\"самоощущение\"] ?? p[\"настроение\"];\n        const mood = toNumber(moodRaw);\n        if (mood !== null) { totalMood += mood; moodCount++; }\n\n        const желание = toBool(p[\"Желание действовать\"] ?? p[\"желание действовать\"]);\n        if (желание) countЖелание++;\n\n        const сонДо23 = toBool(p[\"Сон до 23:00\"] ?? p[\"Сон до 23\"] ?? p[\"сон до 23:00\"]);\n        if (сонДо23) countСонДо23++;\n\n        const доволен = toBool(p[\"Доволен ли продуктивностью\"] ?? p[\"доволен ли продукективностью\"] ?? p[\"доволен продуктивностью\"]);\n        if (доволен) countДоволенПродукт++;\n\n        const unityNum = toNumber(p[\"Unity, часы\"] ?? p[\"Unity часы\"] ?? p[\"Unity\"] ?? p[\"unity\"]);\n        if (unityNum !== null) { totalUnityHours += unityNum; unityCount++; }\n    }\n\n    const avgMood = moodCount > 0 ? Math.round(totalMood / moodCount) : \"—\";\n    const moodEmoji = (typeof avgMood === \"number\") ? (avgMood < 35 ? \"🔴\" : avgMood < 65 ? \"🟡\" : \"🟢\") : \"\";\n    const процент = (n) => Math.round((n / days) * 100);\n\n    const желаниеПроцент = процент(countЖелание);\n    const сонПроцент = процент(countСонДо23);\n    const доволенПроцент = процент(countДоволенПродукт);\n    const unityTotal = Math.round(totalUnityHours * 100) / 100;\n    const unityAvg = unityCount > 0 ? Math.round((totalUnityHours / unityCount) * 100) / 100 : \"—\";\n\n    const colorFor = (pct) => pct >= 80 ? '#4caf50' : pct >= 50 ? '#ff9800' : '#f44336';\n\n    const headers = [\"День\", \"Настроение\", \"Желание действовать\", \"Сон до 23:00\", \"Доволен продуктивностью\", \"Unity, часы\"];\n\n    const summaryRow = [\n        \"Итого / Среднее\",\n        `${moodEmoji} ${avgMood}`,\n        `<span style=\"color:${colorFor(желаниеПроцент)}; font-weight:bold\">${countЖелание}</span> <small style=\"color:#888\">(${желаниеПроцент}%)</small>`,\n        `<span style=\"color:${colorFor(сонПроцент)}; font-weight:bold\">${countСонДо23}</span> <small style=\"color:#888\">(${сонПроцент}%)</small>`,\n        `<span style=\"color:${colorFor(доволенПроцент)}; font-weight:bold\">${countДоволенПродукт}</span> <small style=\"color:#888\">(${доволенПроцент}%)</small>`,\n        `${unityTotal} ч (ср. ${unityAvg})`\n    ];\n\n    const dailyRows = finalPages\n        .sort((a, b) => b._displayDate - a._displayDate)\n        .map(entry => {\n            const p = entry.page;\n            const d = entry._displayDate;\n            const dateStr = (typeof moment === \"function\") ? moment(d).format(\"DD.MM\") : `${String(d.getDate()).padStart(2,'0')}.${String(d.getMonth()+1).padStart(2,'0')}`;\n            const anchor = (typeof moment === \"function\") ? moment(d).format(\"YYYY-MM-DD\") : `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;\n            const link = `[[${p.file.path}#${anchor}|${dateStr}]]`;\n\n            const moodRaw = p[\"Настроение\"] ?? p[\"самоощущение\"] ?? p[\"настроение\"];\n            const mood = toNumber(moodRaw);\n            const moodDisplay = (mood !== null) ? `${mood < 35 ? \"🔴\" : mood < 65 ? \"🟡\" : \"🟢\"} ${Math.round(mood)}` : \"—\";\n\n            const желание = toBool(p[\"Желание действовать\"] ?? p[\"желание действовать\"]);\n            const сон = toBool(p[\"Сон до 23:00\"] ?? p[\"Сон до 23\"] ?? p[\"сон до 23:00\"]);\n            const доволен = toBool(p[\"Доволен ли продуктивностью\"] ?? p[\"доволен ли продукективностью\"] ?? p[\"доволен продуктивностью\"]);\n\n            const unityNum = toNumber(p[\"Unity, часы\"] ?? p[\"Unity часы\"] ?? p[\"Unity\"] ?? p[\"unity\"]);\n            const unityDisplay = unityNum !== null ? `${Math.round(unityNum * 100) / 100}` : \"—\";\n\n            return [\n                link,\n                moodDisplay,\n                желание ? \"✔️\" : \"❌\",\n                сон ? \"✔️\" : \"❌\",\n                доволен ? \"✔️\" : \"❌\",\n                unityDisplay\n            ];\n        });\n\n    dv.table(headers, [summaryRow, ...dailyRows]);\n}\n\n```","x":322,"y":-200,"width":1678,"height":1720,"color":"4"}
	],
	"edges":[]
}