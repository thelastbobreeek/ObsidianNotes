{
	"nodes":[
		{"id":"ff8367e38aee40da","type":"text","text":"# График самоощущения\n```dataviewjs\nconst daysAgo = 30;\nconst endDate = new Date();\nconst startDate = new Date();\nstartDate.setDate(endDate.getDate() - daysAgo);\n\nconst rawPages = dv.pages('\"Дневник/Ежедневник и задачи\"')\n    .filter(p => p.date && typeof p.самоощущение === \"number\");\n\nconst items = [];\nfor (const p of rawPages) {\n    const noteDate = new Date(p.date);\n    if (!isNaN(noteDate.getTime()) && noteDate >= startDate && noteDate <= endDate) {\n        const clampedMood = Math.max(1, Math.min(100, p.самоощущение));\n        items.push({\n            date: noteDate,\n            mood: clampedMood\n        });\n    }\n}\n\nitems.sort((a, b) => a.date - b.date);\n\nif (items.length === 0) {\n    dv.paragraph(\"📉 Нет данных по «самоощущению» за последние 30 дней.\");\n} else {\n    const dates = items.map(item => {\n        const d = item.date;\n        return `${String(d.getDate()).padStart(2, '0')}.${String(d.getMonth() + 1).padStart(2, '0')}`;\n    });\n\n    const feelings = items.map(item => item.mood);\n    const avgMood = Math.round(feelings.reduce((a, b) => a + b, 0) / feelings.length); // ← теперь целое число\n\n    const chartContainer = dv.el(\"div\", \"\");\n    chartContainer.style.height = \"500px\";\n    chartContainer.style.width = \"100%\";\n\n    const chartData = {\n        type: 'line',\n        data: {\n            labels: dates,\n            datasets: [{\n                label: `Самоощущение (среднее: ${avgMood})`,\n                data: feelings,\n                borderColor: 'rgba(75, 192, 192, 1)',\n                backgroundColor: 'rgba(75, 192, 192, 0.1)',\n                borderWidth: 2,\n                pointRadius: 4,\n                pointHoverRadius: 6,\n                fill: true,\n                tension: 0.3\n            }]\n        },\n        options: {\n            animation: false,\n            responsive: true,\n            maintainAspectRatio: false,\n            plugins: {\n                legend: {\n                    position: 'top',\n                    labels: { font: { size: 12 } }\n                },\n                tooltip: {\n                    enabled: true,\n                    mode: 'index',\n                    intersect: false,\n                    padding: 12,\n                    bodyFont: {\n                        size: 14\n                    },\n                    titleFont: {\n                        size: 13,\n                        weight: 'bold'\n                    },\n                    callbacks: {\n                        label: function(context) {\n                            return `Самоощущение: ${context.parsed.y}`;\n                        }\n                    }\n                }\n            },\n            scales: {\n                x: {\n                    title: { display: false },\n                    grid: { display: false }\n                },\n                y: {\n                    min: 1,\n                    max: 100,\n                    ticks: { stepSize: 10, font: { size: 11 } },\n                    grid: { color: 'rgba(200, 200, 200, 0.2)' }\n                }\n            },\n            interaction: {\n                mode: 'nearest',\n                axis: 'x',\n                intersect: false\n            }\n        }\n    };\n\n    window.renderChart(chartData, chartContainer);\n}\n```","x":-760,"y":-400,"width":1060,"height":640,"color":"5"},
		{"id":"73ec8e743db72208","type":"text","text":"# Теги выполненных задач\n```dataviewjs\nconst daysAgo = 30;\nconst endDate = new Date();\nconst startDate = new Date();\nstartDate.setDate(endDate.getDate() - daysAgo);\n\nconst tasks = dv.pages('\"Дневник/Ежедневник и задачи\"')\n    .where(p => p.file.tasks && p.file.tasks.length > 0);\n\nif (!tasks || tasks.length === 0) {\n    dv.paragraph(\"❌ Нет задач.\");\n} else {\n    const filteredTasks = [];\n\n    for (const page of tasks) {\n        for (const task of page.file.tasks) {\n            if (task.completed) {\n                const taskDate = new Date(task.completion);\n                if (!isNaN(taskDate.getTime()) && taskDate >= startDate && taskDate <= endDate) {\n                    if (task.tags && task.tags.length > 0) {\n                        filteredTasks.push(...task.tags);\n                    }\n                }\n            }\n        }\n    }\n\n    if (filteredTasks.length === 0) {\n        dv.paragraph(\"❌ Нет выполненных задач с тегами за последние 30 дней.\");\n    } else {\n        const tagCounts = {};\n        for (const tag of filteredTasks) {\n            tagCounts[tag] = (tagCounts[tag] || 0) + 1;\n        }\n\n        const sortedEntries = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);\n        const labels = sortedEntries.map(entry => entry[0]);\n        const data = sortedEntries.map(entry => entry[1]);\n        const totalValue = data.reduce((a, b) => a + b, 0);\n\n        function generateColor(index, total, opacity = 1) {\n            const hue = (index * 360 / Math.max(1, total)) % 360;\n            return `hsla(${hue}, 70%, 60%, ${opacity})`;\n        }\n\n        const backgroundColors = labels.map((_, i) => generateColor(i, labels.length, 0.75));\n        const borderColors = labels.map((_, i) => generateColor(i, labels.length, 1));\n\n        const chartData = {\n            type: 'pie',\n            data: {  // ← Вот здесь было пропущено \"data:\"\n                labels: labels,\n                datasets: [{\n                    label: 'Частота тегов',\n                    data: data,\n                    backgroundColor: backgroundColors,\n                    borderColor: borderColors,\n                    borderWidth: 2\n                }]\n            },\n            options: {\n                responsive: true,\n                animation: false,\n                plugins: {\n                    legend: {\n                        position: 'top',\n                        labels: {\n                            boxWidth: 28,\n                            padding: 10,\n                            font: { size: 28 },\n                            generateLabels: function(chart) {\n                                const dataset = chart.data.datasets[0];\n                                return chart.data.labels.map((label, i) => {\n                                    const percentage = totalValue ? ((dataset.data[i] / totalValue) * 100).toFixed(1) : 0;\n                                    return {\n                                        text: `${label} ${percentage}%`,\n                                        fillStyle: dataset.backgroundColor[i],\n                                        strokeStyle: dataset.borderColor[i],\n                                        lineWidth: 2,\n                                        hidden: false,\n                                        index: i\n                                    };\n                                });\n                            }\n                        }\n                    },\n                    tooltip: {\n                        callbacks: {\n                            label: function(context) {\n                                const label = context.label || '';\n                                const value = context.raw || 0;\n                                const percentage = totalValue ? ((value / totalValue) * 100).toFixed(1) : 0;\n                                return `${label}: ${value} (${percentage}%)`;\n                            }\n                        },\n                        bodyFont: {\n                            size: 20\n                        },\n                        titleFont: {\n                            size: 22\n                        },\n                        padding: 12,\n                        displayColors: false\n                    },\n                    datalabels: {\n                        formatter: (value, ctx) => {\n                            const percentage = totalValue ? ((value / totalValue) * 100).toFixed(1) : 0;\n                            return `${percentage}%`;\n                        },\n                        color: '#fff',\n                        font: {\n                            weight: 'bold',\n                            size: 12\n                        },\n                        anchor: 'center',\n                        align: 'center'\n                    }\n                }\n            }\n        };\n\n        if (window.Chart && window.ChartDataLabels && !window.Chart.plugins.getAll().some(p => p.id === 'datalabels')) {\n            window.Chart.register(window.ChartDataLabels);\n        } else if (!window.ChartDataLabels) {\n            delete chartData.options.plugins.datalabels;\n        }\n\n        window.renderChart(chartData, this.container);\n    }\n}\n```","x":-760,"y":280,"width":1060,"height":1240,"color":"1"},
		{"id":"6dfacaaa8b49dc71","type":"text","text":"Статистика собирается только из папки `Дневник/Ежедневник и задачи` **(включая все подпапки)**, остальные папки хранилища игнорируются, дабы не тормозило. Если хотите добавить папку для сканирования, отредактируйте код при помощи ИИ.","x":160,"y":1560,"width":811,"height":280},
		{"id":"2ebf8d03cf95f9d8","type":"text","text":"# Оценка рутины\n```dataviewjs\nconst daysAgo = 30;\nconst endDate = new Date();\nconst startDate = new Date();\nstartDate.setDate(endDate.getDate() - daysAgo);\n\n// Фильтруем только валидные страницы с датой\nconst validPages = [];\nfor (let p of dv.pages('\"Дневник/Ежедневник и задачи\"')) {\n    if (!p.file || !p.file.path) continue;\n\n    let pageDate = null;\n\n    // Сначала пробуем взять дату из поля 'date'\n    if (p.date && !isNaN(new Date(p.date).getTime())) {\n        pageDate = new Date(p.date);\n    } \n    // Иначе — из имени файла (ожидаем формат YYYY-MM-DD.md)\n    else if (p.file.name) {\n        const nameWithoutExt = p.file.name.includes('.') ? p.file.name.split('.')[0] : p.file.name;\n        const dateFromName = new Date(nameWithoutExt);\n        if (!isNaN(dateFromName.getTime())) {\n            pageDate = dateFromName;\n        }\n    }\n\n    if (pageDate && p;ageDate >= startDate && pageDate <= endDate) {\n        validPages.push({ ...p, _displayDate: pageDate });\n    }\n}\n\nif (validPages.length === 0) {\n    dv.paragraph(\"❌ Нет данных за последние 30 дней.\");\n} else {\n    const days = validPages.length;\n    let желаниеДействовать = 0;\n    let totalMood = 0, moodCount = 0;\n\n    for (const p of validPages) {\n        if (p[\"желание действовать\"] === true) желаниеДействовать++;\n        if (typeof p[\"самоощущение\"] === \"number\") {\n            totalMood += p[\"самоощущение\"];\n            moodCount++;\n        }\n    }\n\n    // Среднее как целое число\n    const психикаAvg = moodCount > 0 ? Math.round(totalMood / moodCount) : \"—\";\n    \n    // Эмодзи для среднего\n    const avgEmoji = typeof психикаAvg === \"number\"\n        ? (психикаAvg < 35 ? \"🔴\" : психикаAvg < 65 ? \"🟡\" : \"🟢\")\n        : \"\";\n\n    const желаниеПроцент = Math.round((желаниеДействовать / days) * 100);\n    const желаниеЦвет = желаниеПроцент >= 80 ? '#4caf50' : желаниеПроцент >= 50 ? '#ff9800' : '#f44336';\n\n    const summaryRow = [\n        \"Итого / Среднее\",\n        `${avgEmoji} ${психикаAvg}`,\n        `<span style=\"color:${желаниеЦвет}; font-weight:bold\">${желаниеДействовать}</span> <small style=\"color:#888\">(${желаниеПроцент}%)</small>`\n    ];\n\n    const dailyRows = validPages\n        .sort((a, b) => b._displayDate - a._displayDate)\n        .map(p => {\n            const dateStr = moment(p._displayDate).format(\"DD.MM\");\n            const anchor = moment(p._displayDate).format(\"YYYY-MM-DD\");\n            const link = `[[${p.file.path}#${anchor}|${dateStr}]]`;\n\n            let самоощущениеDisplay = \"❌\";\n            if (typeof p[\"самоощущение\"] === \"number\") {\n                const value = Math.round(p[\"самоощущение\"]);\n                const emoji = value < 35 ? \"🔴\" : value < 65 ? \"🟡\" : \"🟢\";\n                самоощущениеDisplay = `${emoji} ${value}`;\n            }\n\n            return [\n                link,\n                самоощущениеDisplay,\n                p[\"желание действовать\"] ? \"✔️\" : \"❌\"\n            ];\n        });\n\n    const headers = [\"День\", \"Самоощущение\", \"Желание действовать\"];\n\n    dv.table(headers, [summaryRow, ...dailyRows]);\n}\n```","x":360,"y":-160,"width":1678,"height":1720,"color":"4"},
		{"id":"c0213d0257a02f3c","type":"text","text":"```dataviewjs\nconst now = window.moment();\nconst thirtyDaysAgo = now.clone().subtract(30, 'days');\n\nlet completed = 0;\nlet cancelled = 0;\n\nfor (const page of dv.pages('\"Дневник/Ежедневник и задачи\"')) {\n    const mDate = window.moment(page.file.day);\n    if (!mDate.isValid() || mDate.isBefore(thirtyDaysAgo) || mDate.isAfter(now)) continue;\n    if (!page.file.tasks) continue;\n\n    for (const t of page.file.tasks) {\n        if (t.status === 'x') completed++;\n        else if (t.status === '-') cancelled++;\n    }\n}\n\ndv.table([\"✅ Завершено\", \"❌ Отменено\"], [[completed.toString(), cancelled.toString()]]);\n```\n","x":360,"y":-400,"width":1678,"height":200,"color":"3"}
	],
	"edges":[]
}